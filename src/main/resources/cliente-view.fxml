<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.marcelli.sistemacaixa.controller.ClienteController"
      spacing="10"
      alignment="CENTER">
    <TextField fx:id="cpfField" promptText="CPF"/>
    <TextField fx:id="nomeField" promptText="Nome do Cliente"/>
    <Button text="Salvar" onAction="#salvarCliente"/>
</VBox>
